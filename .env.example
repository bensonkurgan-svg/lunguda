APP_NAME="Lunguda Heritage Archive"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Lagos
APP_URL=http://localhost
APP_LOCALE=en

# Force HTTPS when behind Railway's proxy (set true in production)
FORCE_HTTPS=false

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database ---------------------------------------------------------------
# Railway injects these automatically when you attach a MySQL or Postgres plugin.
# For MySQL use DB_CONNECTION=mysql; for Postgres use DB_CONNECTION=pgsql.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lunguda
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Media storage ----------------------------------------------------------
# Default 'public' disk works with a Railway VOLUME mounted at storage/app/public.
# For durable object storage instead, set FILESYSTEM_DISK=s3 and fill these
# (works with AWS S3 or Cloudflare R2 — see docs/DEPLOY_RAILWAY.md).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@lunguda.org"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
